{
  "name": "@yh-ui/request",
  "version": "0.1.42",
  "description": "YH-UI HTTP request hooks - Enterprise-grade request management",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.mjs",
      "require": "./dist/*.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --stub",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "prepack": "node ../../scripts/prepare-package-manifest.mjs prepare",
    "postpack": "node ../../scripts/prepare-package-manifest.mjs restore"
  },
  "dependencies": {
    "@yh-ui/utils": "workspace:*"
  },
  "devDependencies": {
    "vue": "catalog:",
    "vue-tsc": "^2.2.0"
  },
  "peerDependencies": {
    "vue": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/1079161148/yh-ui.git",
    "directory": "packages/request"
  },
  "keywords": [
    "yh-ui",
    "request",
    "http",
    "fetch",
    "hooks",
    "sse",
    "streaming"
  ],
  "homepage": "https://1079161148.github.io/yh-ui/",
  "author": "YH-UI Team",
  "license": "MIT"
}
