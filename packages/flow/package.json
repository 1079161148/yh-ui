{
  "name": "@yh-ui/flow",
  "version": "1.0.53",
  "description": "YH-UI High-performance Flow Chart Component",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.mjs",
      "require": "./dist/*.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild && rimraf dist/__tests__",
    "dev": "unbuild --stub",
    "prepack": "node ../../scripts/prepare-package-manifest.mjs prepare",
    "postpack": "node ../../scripts/prepare-package-manifest.mjs restore",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@yh-ui/utils": "workspace:*",
    "@yh-ui/hooks": "workspace:*"
  },
  "devDependencies": {
    "vue": "catalog:",
    "vue-tsc": "^2.2.0",
    "vue-sfc-transformer": "^0.1.17"
  },
  "peerDependencies": {
    "vue": "catalog:",
    "dagre": ">=0.8.5",
    "elkjs": ">=0.9.0",
    "d3-force": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "dagre": {
      "optional": true
    },
    "elkjs": {
      "optional": true
    },
    "d3-force": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/1079161148/yh-ui.git",
    "directory": "packages/flow"
  },
  "keywords": [
    "yh-ui",
    "flow",
    "flow-chart",
    "node-editor",
    "vue-flow",
    "diagram"
  ],
  "homepage": "https://1079161148.github.io/yh-ui/",
  "author": "YH-UI Team",
  "license": "MIT"
}
