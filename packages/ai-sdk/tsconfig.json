{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "noEmit": true,
    "emitDeclarationOnly": false,
    "baseUrl": ".",
    "rootDir": "../../",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["node", "vite/client"],
    "paths": {
      "@yh-ui/components": ["../components/src"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue"],
  "exclude": ["**/__tests__", "**/*.test.ts", "dist"]
}
