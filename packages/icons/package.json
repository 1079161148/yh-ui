{
  "name": "@yh-ui/icons",
  "version": "1.0.3",
  "description": "YH-UI Icons - High performance icon library with Iconify integration",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    },
    "./vue": {
      "import": "./dist/vue/icon.mjs",
      "types": "./dist/src/vue/icon.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "yh-ui",
    "icon",
    "icons",
    "iconify",
    "svg"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint ."
  },
  "author": "YH-UI Team",
  "homepage": "https://1079161148.github.io/yh-ui/",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/1079161148/yh-ui.git",
    "directory": "packages/icons"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@iconify/vue": "^4.1.2"
  },
  "devDependencies": {
    "unplugin-icons": "^0.20.1",
    "@iconify/json": "^2.2.268"
  }
}
