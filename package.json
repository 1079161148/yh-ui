{
  "name": "yh-ui-monorepo",
  "version": "1.0.40",
  "private": true,
  "description": "YH-UI - A Modern Vue 3 Component Library",
  "type": "module",
  "scripts": {
    "dev": "pnpm -C playground dev",
    "starter:dev": "pnpm -C apps/ai-ops-starter dev",
    "starter:dev:workspace": "pnpm -C apps/ai-ops-starter dev:workspace",
    "starter:build": "pnpm -C apps/ai-ops-starter build",
    "starter:build:workspace": "pnpm -C apps/ai-ops-starter build:workspace",
    "starter:preview": "pnpm -C apps/ai-ops-starter preview",
    "starter:preview:workspace": "pnpm -C apps/ai-ops-starter preview:workspace",
    "build": "pnpm run -r --filter=./packages/* build",
    "build:components": "pnpm -C packages/components build",
    "build:ai-sdk": "pnpm -C packages/ai-sdk build",
    "build:skill": "pnpm -C packages/yh-ui-skill build",
    "build:theme": "pnpm -C packages/theme build",
    "build:utils": "pnpm -C packages/utils build",
    "build:hooks": "pnpm -C packages/hooks build",
    "build:locale": "pnpm -C packages/locale build",
    "build:icons": "pnpm -C packages/icons build",
    "build:nuxt": "pnpm -C packages/nuxt build",
    "build:flow": "pnpm -C packages/flow build",
    "sync:docs-public": "node scripts/sync-docs-public-packages.mjs",
    "build:playground-runtime": "node --max-old-space-size=6144 scripts/build-playground-runtime.mjs",
    "build:codesandbox-runtime": "node --max-old-space-size=6144 scripts/build-codesandbox-runtime.mjs",
    "docs:dev": "pnpm -C docs dev",
    "docs:build": "pnpm -C docs build",
    "docs:preview": "pnpm -C docs preview",
    "verify:stackblitz-local": "vite-node scripts/validate-demo-sandbox.mts",
    "verify:release-versions": "node scripts/verify-release-versions.mjs",
    "verify:packed-manifests": "node scripts/verify-packed-manifests.mjs",
    "verify:docs": "pnpm docs:build && pnpm verify:docs-playground",
    "verify:docs-playground": "vite-node scripts/verify-docs-playground.mts",
    "verify:docs-sandboxes": "node scripts/run-docs-sandbox-validation.mjs smoke",
    "verify:docs-sandboxes:exhaustive": "node scripts/run-docs-sandbox-validation.mjs exhaustive",
    "verify:docs-i18n": "node scripts/verify-docs-i18n.mjs",
    "generate:yh-ui-skill": "node scripts/generate-yh-ui-skill.mjs",
    "verify:yh-ui-skill": "node scripts/verify-yh-ui-skill.mjs",
    "verify:package-size": "node scripts/verify-package-size.mjs",
    "verify:a11y": "node scripts/verify-a11y.mjs",
    "verify:visual-regression": "node scripts/verify-visual-regression.mjs",
    "verify:component-quality": "node scripts/verify-component-quality.mjs",
    "verify:consumer-smoke": "node scripts/verify-consumer-smoke.mjs",
    "verify:playgrounds": "node scripts/verify-playgrounds.mjs",
    "verify:codesandbox-local": "vite-node scripts/verify-codesandbox-local.mts",
    "verify:codesandbox-remote": "vite-node scripts/verify-codesandbox-remote.mts",
    "verify:published-release": "node scripts/verify-published-release.mjs",
    "verify:open-source-release": "node scripts/verify-open-source-release.mjs",
    "changelog:prepare": "node scripts/update-changelog.mjs",
    "changelog:check": "node scripts/update-changelog.mjs --check",
    "release-notes:extract": "node scripts/extract-release-notes.mjs",
    "test": "vitest --project components-dom --project packages-dom --project packages-node --project ssr",
    "test:run": "node --max-old-space-size=4096 ./node_modules/vitest/vitest.mjs run",
    "test:coverage": "node ./scripts/run-vitest-coverage.mjs",
    "test:perf": "node --max-old-space-size=4096 ./node_modules/vitest/vitest.mjs run --project perf",
    "test:ci": "node --max-old-space-size=4096 ./node_modules/vitest/vitest.mjs run --project components-dom --project packages-dom --project packages-node --project ssr",
    "test:coverage:ai-sdk": "node ./node_modules/vitest/vitest.mjs run --coverage packages/ai-sdk/__tests__ --coverage.include=packages/ai-sdk/src/**/*.ts --coverage.thresholds.lines=80 --coverage.thresholds.branches=80 --coverage.thresholds.functions=80 --coverage.thresholds.statements=80",
    "test:coverage:request": "node ./node_modules/vitest/vitest.mjs run --coverage packages/request/src/__tests__ --coverage.include=packages/request/src/**/*.ts --coverage.thresholds.lines=80 --coverage.thresholds.branches=80 --coverage.thresholds.functions=80 --coverage.thresholds.statements=80",
    "coverage:branch-exclude": "node ./scripts/generate-branch-coverage-exclude.mjs",
    "test:coverage:component-system": "node ./scripts/run-component-system-coverage.mjs",
    "test:coverage:component-system:stage1": "node ./scripts/run-component-system-coverage.mjs && node ./scripts/verify-component-system-coverage.mjs stage1",
    "test:coverage:component-system:stage2": "node ./scripts/run-component-system-coverage.mjs && node ./scripts/verify-component-system-coverage.mjs stage2",
    "test:coverage:component-system:stage3": "node ./scripts/run-component-system-coverage.mjs && node ./scripts/verify-component-system-coverage.mjs stage3",
    "verify:coverage:component-system": "node ./scripts/verify-component-system-coverage.mjs",
    "lint": "eslint . --cache --max-warnings 0",
    "lint:fix": "eslint . --fix --cache --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .github/workflows/extended-validation.yml .github/workflows/pr-check.yml .github/workflows/release.yml package.json vitest.config.ts scripts/extract-release-notes.mjs scripts/generate-branch-coverage-exclude.mjs scripts/generate-component-system-coverage-exclude.mjs scripts/packed-manifest-utils.mjs scripts/prepare-package-manifest.mjs scripts/publish-unpublished-packages.mjs scripts/report-component-system-coverage.mjs scripts/run-component-system-coverage.mjs scripts/run-docs-sandbox-validation.mjs scripts/run-vitest-coverage.mjs scripts/update-changelog.mjs scripts/validate-demo-sandbox.mts scripts/verify-a11y.mjs scripts/verify-codesandbox-local.mts scripts/verify-codesandbox-remote.mts scripts/verify-component-quality.mjs scripts/verify-consumer-smoke.mjs scripts/verify-docs-i18n.mjs scripts/verify-docs-playground.mts scripts/verify-docs-sandboxes-exhaustive.mts scripts/verify-open-source-release.mjs scripts/verify-package-size.mjs scripts/verify-packed-manifests.mjs scripts/verify-playgrounds.mjs scripts/verify-visual-regression.mjs scripts/wait-for-published-packages.mjs test/setup/vitest.dom.ts README.md CHANGELOG.md RELEASE_VALIDATION.md COMPONENT_QUALITY_MATRIX.md playground/index.html",
    "typecheck": "vue-tsc --noEmit",
    "clean": "rimraf node_modules **/node_modules **/dist",
    "postinstall": "node scripts/postinstall.mjs",
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky",
    "version:patch": "bumpp package.json packages/*/package.json --no-push --no-tag --no-commit && pnpm changelog:prepare",
    "version:minor": "bumpp package.json packages/*/package.json --minor --no-push --no-tag --no-commit && pnpm changelog:prepare",
    "version:major": "bumpp package.json packages/*/package.json --major --no-push --no-tag --no-commit && pnpm changelog:prepare",
    "verify:prepush": "node scripts/pre-push.mjs",
    "verify:prepush:full": "pnpm format:check && pnpm typecheck && pnpm lint && pnpm test:ci && pnpm build && pnpm verify:package-size && pnpm verify:component-quality && pnpm verify:consumer-smoke && pnpm verify:playgrounds && pnpm verify:docs-i18n && pnpm verify:docs",
    "verify:release": "pnpm build && pnpm verify:package-size && pnpm verify:release-versions && pnpm verify:packed-manifests && pnpm changelog:check && pnpm verify:component-quality && pnpm verify:consumer-smoke && pnpm verify:playgrounds && pnpm docs:build && pnpm verify:docs-i18n && pnpm verify:stackblitz-local && pnpm verify:docs-sandboxes && pnpm verify:codesandbox-local && pnpm verify:docs-playground",
    "release": "pnpm typecheck && pnpm lint && pnpm test:ci && bumpp package.json packages/*/package.json --execute \"pnpm changelog:prepare && pnpm changelog:check\" --commit \"chore(release): v%s\" --push --tag",
    "publish:all": "node scripts/publish-unpublished-packages.mjs",
    "wait:published-packages": "node scripts/wait-for-published-packages.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@langchain/core": ">=0.3.0",
    "@types/dagre": "^0.7.54",
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vitejs/plugin-vue-jsx": "^5.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/compiler-sfc": "^3.5.27",
    "@vue/compiler-vue2": "^2.7.16",
    "@vue/server-renderer": "^3.5.27",
    "@vue/test-utils": "^2.4.6",
    "bumpp": "^10.4.1",
    "dagre": "^0.8.5",
    "esbuild": "^0.25.9",
    "eslint": "^9.18.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-vue": "^9.32.0",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^16.6.0",
    "html-to-image": "^1.11.13",
    "husky": "^9.1.7",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "lint-staged": "^15.3.0",
    "ai": "4.3.19",
    "picomatch": "^4.0.4",
    "pinia": "^3.0.4",
    "playwright": "^1.58.2",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "rollup": "^4.59.1",
    "sass": "^1.83.1",
    "typescript": "^5.7.3",
    "unbuild": "^3.6.1",
    "vite": "^6.0.7",
    "vite-plugin-dts": "^4.4.0",
    "vitest": "^4.0.18",
    "vue": "^3.5.27",
    "vue-router": "^4.6.4",
    "vue-tsc": "^2.2.0",
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=11.5.0 <12.0.0"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,vue}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{css,scss,md,json}": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/1079161148/yh-ui.git"
  },
  "keywords": [
    "vue",
    "vue3",
    "component-library",
    "ui-components",
    "yh-ui"
  ],
  "homepage": "https://1079161148.github.io/yh-ui/",
  "author": "YH-UI Team",
  "license": "MIT",
  "dependencies": {
    "@floating-ui/dom": "^1.7.4",
    "async-validator": "^4.2.5",
    "dayjs": "^1.11.19",
    "echarts": "^6.0.0",
    "xlsx": "^0.18.5"
  }
}
