{
  "name": "yh-ui-docs",
  "version": "0.1.10",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node ../scripts/sync-docs-public-packages.mjs && node --max-old-space-size=6144 ../scripts/build-playground-runtime.mjs && node --max-old-space-size=6144 ../scripts/build-codesandbox-runtime.mjs",
    "dev": "vitepress dev",
    "prebuild": "node ../scripts/sync-docs-public-packages.mjs && node --max-old-space-size=6144 ../scripts/build-playground-runtime.mjs && node --max-old-space-size=6144 ../scripts/build-codesandbox-runtime.mjs",
    "build": "node --max-old-space-size=8192 ../node_modules/vitepress/dist/node/cli.js build",
    "preview": "vitepress preview"
  },
  "dependencies": {
    "@yh-ui/components": "workspace:*",
    "@yh-ui/flow": "workspace:*",
    "@yh-ui/icons": "workspace:*",
    "@yh-ui/request": "workspace:*",
    "@yh-ui/theme": "workspace:*",
    "@yh-ui/yh-ui": "workspace:*",
    "dayjs": "^1.11.19",
    "echarts": "^6.0.0",
    "highlight.js": "^11.11.1",
    "mermaid": "11.12.3"
  },
  "devDependencies": {
    "@stackblitz/sdk": "^1.11.0",
    "@vue/repl": "^4.7.1",
    "lz-string": "^1.5.0",
    "monaco-editor": "^0.55.1",
    "sass": "^1.83.1",
    "vitepress": "^1.5.0",
    "vue": "^3.5.13"
  }
}
